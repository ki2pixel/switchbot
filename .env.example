# SwitchBot API v1.1 credentials
# Get these from the SwitchBot app (Developer Options)
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=

# Retry settings (network instability)
# Default behavior is 2 attempts total (1 retry) with 10 seconds delay
SWITCHBOT_RETRY_ATTEMPTS=2
SWITCHBOT_RETRY_DELAY_SECONDS=10

# Poll interval override (seconds, >=15)
SWITCHBOT_POLL_INTERVAL_SECONDS=60

# APScheduler configuration
# Set to "false" to disable internal scheduler (e.g., when using external cron)
SCHEDULER_ENABLED=true

# Flask settings
FLASK_SECRET_KEY=change-me
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0

# Optional: override config paths
# SWITCHBOT_SETTINGS_PATH=/absolute/path/to/settings.json
# SWITCHBOT_STATE_PATH=/absolute/path/to/state.json

# Storage backend configuration
# STORE_BACKEND=postgres (recommended) or filesystem (fallback)
# POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# POSTGRES_SSL_MODE=require (default, for Neon PostgreSQL)

# Legacy Redis configuration (deprecated, use PostgreSQL instead)
# STORE_BACKEND=redis
# REDIS_URL_PRIMARY=rediss://default:password@host:6379/0
# REDIS_URL_SECONDARY=rediss://default:password@host2:6380/0
# REDIS_URL=rediss://default:password@host:6379/0  # Legacy single-URL (fallback to PRIMARY if unset)
# REDIS_PREFIX=switchbot_dashboard
# REDIS_TTL_SECONDS=86400

# Timezone configuration (IANA timezone identifiers)
# TIMEZONE=Europe/Paris

# IFTTT Webhooks configuration (optional, overrides settings.json if defined)
# IFTTT_WEBHOOK_WINTER=https://maker.ifttt.com/trigger/switchbot_winter/with/key/YOUR_IFTTT_KEY
# IFTTT_WEBHOOK_SUMMER=https://maker.ifttt.com/trigger/switchbot_summer/with/key/YOUR_IFTTT_KEY
# IFTTT_WEBHOOK_FAN=https://maker.ifttt.com/trigger/switchbot_fan/with/key/YOUR_IFTTT_KEY
# IFTTT_WEBHOOK_OFF=https://maker.ifttt.com/trigger/switchbot_off/with/key/YOUR_IFTTT_KEY
