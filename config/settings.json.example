{
  "automation_enabled": true,
  "mode": "winter",
  "poll_interval_seconds": 30,
  "hysteresis_celsius": 0.3,
  "command_cooldown_seconds": 60,
  "action_on_cooldown_seconds": 420,
  "action_off_cooldown_seconds": 60,
  "off_repeat_count": 2,
  "off_repeat_interval_seconds": 10,
  "turn_off_outside_windows": true,
  "timezone": "Europe/Paris",
  "api_quota_warning_threshold": 250,
  "meter_device_id": "YOUR_METER_DEVICE_ID",
  "aircon_device_id": "YOUR_AIRCON_DEVICE_ID",
  "winter": {
    "min_temp": 23.0,
    "max_temp": 25.0,
    "target_temp": 26.0,
    "fan_speed": 3,
    "ac_mode": 5
  },
  "summer": {
    "min_temp": 23.0,
    "max_temp": 26.0,
    "target_temp": 24.0,
    "fan_speed": 3,
    "ac_mode": 2
  },
  "aircon_scenes": {
    "winter": "YOUR_WINTER_SCENE_UUID",
    "summer": "YOUR_SUMMER_SCENE_UUID",
    "fan": "YOUR_FAN_SCENE_UUID",
    "off": "YOUR_OFF_SCENE_UUID"
  },
  "ifttt_webhooks": {
    "winter": "https://maker.ifttt.com/trigger/switchbot_winter/with/key/YOUR_IFTTT_KEY",
    "summer": "https://maker.ifttt.com/trigger/switchbot_summer/with/key/YOUR_IFTTT_KEY",
    "fan": "https://maker.ifttt.com/trigger/switchbot_fan/with/key/YOUR_IFTTT_KEY",
    "off": "https://maker.ifttt.com/trigger/switchbot_off/with/key/YOUR_IFTTT_KEY"
  },
  "time_windows": [
    {
      "days": [0, 1, 2, 3, 4, 5, 6],
      "start": "10:00",
      "end": "01:00"
    }
  ]
}
